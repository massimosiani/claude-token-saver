#!/usr/bin/env bash
# SessionStart hook for token-efficient-setup plugin
# Checks if CLAUDE.md has a Token Efficiency section; if not, reminds the user.

set -euo pipefail

# Check for Token Efficiency section in project CLAUDE.md
if [ -f "CLAUDE.md" ] && grep -q "Token Efficiency" "CLAUDE.md" 2>/dev/null; then
  exit 0
fi

# Also check global CLAUDE.md
if [ -f "${HOME}/.claude/CLAUDE.md" ] && grep -q "Token Efficiency" "${HOME}/.claude/CLAUDE.md" 2>/dev/null; then
  exit 0
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

message="No token-efficient rules found in CLAUDE.md. Run /claude-token-saver to add them."
escaped=$(escape_for_json "$message")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"

exit 0
